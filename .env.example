# ============================================
# Tippad Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
#
# IMPORTANT: Never commit .env to version control!
# ============================================

# Network: mainnet | sepolia | goerli | localhost | hardhat
# Default: sepolia (development), mainnet (production)
VITE_NETWORK=sepolia

# TippadRegistry Contract Address
# Overrides the default address for the selected network.
# Must be a valid Ethereum address (0x + 40 hex characters).
VITE_TIPPAD_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# Custom RPC URL (optional — overrides network default)
# Get a free key from https://www.alchemy.com or https://infura.io
# VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Chain ID (optional — overrides network default)
# VITE_CHAIN_ID=11155111

# Block Explorer URL (optional — overrides network default)
# VITE_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io
